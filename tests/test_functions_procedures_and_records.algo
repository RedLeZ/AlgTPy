algorithme functions_procedures_and_records

// Type declarations with records
TDNT
	eleve = enregistrement
		nom : chaine,
		age : entier,
	fin
fin_tdnt

TDO
	x : entier
	y : reel
	tab : tableau de 5 entier
fin_tdo

Debut

// Simple arithmetic with multiple types
x <- 10
y <- 3.14
ecrire(x+y)

// Procedure with parameters
Procédure afficherTab(@ t : tableau entier, n : entier)
Debut
	Pour i de 0 à n-1 faire
		t[i] <- i * i + 1
		ecrire(t)
	fin_pour
Fin

// Call procedure
afficherTab(@tab, 5)

// Function with return
Fonction cube(n : entier) : entier
Debut
	s <- n*n*n
	retourner s
Fin

ecrire(cube(3))

Fin
